    given-names: Mohammadali
    alias: Mo MassJedi
url: "https://github.com/MohammadaliMasjedi-source/rpi-camera-af"
keywords:
  - raspberry-pi
  - autofocus
  - servo-motor
  - computer-vision
  - 3d-printing
